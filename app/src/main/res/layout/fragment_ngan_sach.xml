<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txt_ngansach_thangnam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngân sách Tháng"
            android:textColor="#1F2937"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hạn mức chi tiêu tối đa:"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_ngansach_hanmuc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textColor="#1F2937"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB"
                android:layout_marginBottom="15dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📉 Đã chi tiêu:"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txt_ngansach_tongchi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 đ"
                        android:textColor="#EF4444"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 Ví còn lại:"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txt_ngansach_conlai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 đ"
                        android:textColor="#10B981"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/prg_ngansach_tiendo"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:max="100"
                android:progress="0" />

        </LinearLayout>

        <TextView
            android:id="@+id/txt_ngansach_canhbao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hệ thống đang phân tích chi tiêu..."
            android:textColor="#4B5563"
            android:textSize="15sp"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginBottom="30dp"
            android:padding="10dp"/>

        <Button
            android:id="@+id/btn_thiet_lap_han_muc"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="THIẾT LẬP HẠN MỨC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#0ea5e9"/>

    </LinearLayout>
</ScrollView>