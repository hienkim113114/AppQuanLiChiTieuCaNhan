<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/img_item_bieutuong"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:contentDescription="Icon danh mục"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_item_tendanhmuc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ăn uống"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_item_ghichu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Mua cơm trưa văn phòng"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_item_ngay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="2026-05-25"
                android:textColor="#94A3B8"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_item_sotien"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-50.000 đ"
            android:textColor="#EF4444"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>