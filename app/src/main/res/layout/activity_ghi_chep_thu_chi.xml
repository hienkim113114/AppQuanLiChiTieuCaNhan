<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">


            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/img_3" />


            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GHI CHÉP THU CHI"
                    android:textColor="#0F172A"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Quản lý dòng tiền, kiểm soát tài chính"
                    android:textColor="#64748B"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHÂN LOẠI DÒNG TIỀN"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_loai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <!-- KHOẢN CHI -->
                <RadioButton
                    android:id="@+id/rb_chi"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="#FFF1F2"
                    android:buttonTint="#EF4444"
                    android:checked="true"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Khoản CHI (-)\nTiền đi ra"
                    android:textAlignment="center"
                    android:textColor="#EF4444"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- KHOẢN THU -->
                <RadioButton
                    android:id="@+id/rb_thu"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="#F0FDF4"
                    android:buttonTint="#10B981"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Khoản THU (+)\nTiền đi vào"
                    android:textAlignment="center"
                    android:textColor="#10B981"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </RadioGroup>

        </LinearLayout>

        <!-- CARD FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SỐ TIỀN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰  SỐ TIỀN (đ)"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_sotien"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:hint="Nhập số tiền phát sinh..."
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="🏷️  DANH MỤC PHÂN LOẠI"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spn_danhmuc"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:padding="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="📅  NGÀY THÁNG"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_ngay"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:clickable="true"
                android:focusable="false"
                android:hint="Chọn ngày phát sinh (YYYY-MM-DD)"
                android:paddingStart="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:textSize="17sp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="📝  GHI CHÚ THÊM"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_ghichu"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:gravity="top|start"
                android:hint="Nội dung chi tiết (Ví dụ: Ăn bún chả cùng đồng nghiệp...)"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:textSize="16sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_luu"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#0F6FFF"
            android:text="💾  HOÀN TẤT VÀ LƯU"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>