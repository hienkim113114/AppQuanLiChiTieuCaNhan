<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F1F5F9">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thống Kê Chi Tiêu"
        android:textColor="#0F172A"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btn_thang_truoc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:backgroundTint="#0F172A"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/txt_hien_thi_thang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tháng 05/2026"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <Button
            android:id="@+id/btn_thang_sau"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:backgroundTint="#0F172A"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <com.github.mikephil.charting.charts.PieChart
        android:id="@+id/pie_chart_thongke"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>